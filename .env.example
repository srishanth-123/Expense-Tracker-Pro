# ====================================================
# Expense Tracker Pro — Environment Template
# ====================================================

# ----------------- Backend Configuration -----------------
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/expense-tracker?retryWrites=true&w=majority

# JWT Authentication (Use 64-char hex key in production)
JWT_SECRET=your_64_character_hex_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_separate_64_character_hex_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Upstash Redis REST API (for rate limiting, L2 caching)
REDIS_URL=https://your-redis-instance.upstash.io
REDIS_TOKEN=your_upstash_redis_token

# Upstash Redis TCP (for BullMQ queues + Socket.io adapter)
REDIS_IOREDIS_URL=rediss://default:your_password@your-endpoint.upstash.io:6379

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cookie Secret
COOKIE_SECRET=your_cookie_secret_here

# ----------------- Frontend Configuration -----------------
# API Endpoint
VITE_API_URL=http://localhost:5000/api
