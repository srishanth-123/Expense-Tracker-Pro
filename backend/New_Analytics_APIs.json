{
  "info": {
    "name": "Expense Tracker - New Analytics APIs",
    "description": "Isolated collection containing only the new advanced analytics endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Analytics (Advanced)",
      "item": [
        {
          "name": "Top Expenses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/top-expenses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "analytics",
                "top-expenses"
              ]
            }
          }
        },
        {
          "name": "Category Trend",
          "request": {
