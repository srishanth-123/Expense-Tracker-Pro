# ====================================================
# Expense Tracker — Environment Variables Template
# Copy this file to .env and fill in your values.
# ====================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/expense-tracker?retryWrites=true&w=majority

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_hex_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_separate_64_character_hex_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Upstash Redis REST (for rate limiting, caching)
REDIS_URL=https://your-redis-instance.upstash.io
REDIS_TOKEN=your_upstash_redis_token

# Upstash Redis TCP (for BullMQ + Socket.io Adapter)
# Get this from Upstash Dashboard → your DB → Connect → ioredis
REDIS_IOREDIS_URL=rediss://default:your_password@your-endpoint.upstash.io:6379

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cookie
COOKIE_SECRET=your_cookie_secret_here
